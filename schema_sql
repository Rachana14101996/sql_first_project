-- Create a simple database and table
CREATE DATABASE Rach;
USE Rach;

CREATE TABLE employees (
    id INT PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(50),
    role VARCHAR(50),
    salary DECIMAL(10,2)
);

